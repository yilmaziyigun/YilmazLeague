@model List<YilmazLeague.WebUI.Dtos.MatchDto>
@{
    ViewData["Title"] = "Canlı Skorlar";
    var matches = (Model ?? new List<YilmazLeague.WebUI.Dtos.MatchDto>())
        .OrderByDescending(x => x.LiveMinute ?? 0)
        .ThenBy(x => x.MatchDate)
        .ToList();
}
@section Styles{
<style>
:root{--bg:#080d18;--bg2:#0c1220;--card:#111827;--card2:#16202f;--line:#1a2640;--green:#00e676;--blue:#2979ff;--live:#ff1744;--gold:#ffd600;--t1:#eef2ff;--t2:#7b96c4;--t3:#3d5478;--r1:8px;--r2:12px;--r3:16px;--fd:'Barlow Condensed',sans-serif;--fb:'Barlow',sans-serif}body{font-family:var(--fb);background:var(--bg);color:var(--t1);min-height:100vh;background-image:radial-gradient(ellipse at 15% 0%,rgba(255,23,68,.10) 0%,transparent 52%),radial-gradient(ellipse at 90% 10%,rgba(41,121,255,.08) 0%,transparent 45%)}a{text-decoration:none;color:inherit}.wrap{max-width:1120px;margin:0 auto;padding:0 20px}.nb{background:rgba(8,13,24,.96);border-bottom:1px solid var(--line);position:sticky;top:0;z-index:1000}.nb-inner{max-width:1120px;margin:0 auto;padding:0 20px;display:flex;align-items:center;justify-content:space-between}.brand{display:flex;align-items:center;gap:10px;padding:14px 0}.brand-ico{width:34px;height:34px;background:linear-gradient(135deg,var(--green),var(--blue));border-radius:7px;display:flex;align-items:center;justify-content:center}.brand-txt{font-family:var(--fd);font-size:21px;font-weight:800}.brand-txt span{color:var(--green)}.nav-links{display:flex}.nl{font-family:var(--fd);font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--t2);padding:22px 15px;position:relative}.nl::after{content:'';position:absolute;bottom:0;left:15px;right:15px;height:2px;background:var(--live);transform:scaleX(0);transition:.2s}.nl.active,.nl:hover{color:var(--t1)}.nl.active::after,.nl:hover::after{transform:scaleX(1)}.hero{border-bottom:1px solid var(--line);background:linear-gradient(135deg,rgba(255,23,68,.14),rgba(17,24,39,.82));padding:34px 0 28px}.hero-grid{display:grid;grid-template-columns:1fr auto;gap:18px;align-items:end}.badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,23,68,.10);border:1px solid rgba(255,23,68,.25);border-radius:20px;padding:5px 12px;font-family:var(--fd);font-size:11px;font-weight:800;letter-spacing:1px;color:var(--live);text-transform:uppercase}.title{font-family:var(--fd);font-size:clamp(34px,6vw,58px);font-weight:900;margin-top:10px}.sub{font-size:13px;color:var(--t2)}.onair{display:grid;grid-template-columns:repeat(3,92px);gap:10px}.onair-box{background:rgba(17,24,39,.82);border:1px solid var(--line);border-radius:var(--r2);padding:12px;text-align:center}.onair-num{font-family:var(--fd);font-size:30px;font-weight:900;color:var(--live)}.onair-label{font-size:10px;color:var(--t3);letter-spacing:1px;text-transform:uppercase}.content{padding:28px 0 56px}.live-list{display:grid;gap:14px}.live-row{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:18px;background:linear-gradient(135deg,var(--card),var(--card2));border:1px solid rgba(255,23,68,.22);border-radius:var(--r3);padding:20px 24px;transition:.2s;position:relative;overflow:hidden}.live-row::before{content:'';position:absolute;left:0;top:20px;bottom:20px;width:3px;background:var(--live);border-radius:0 6px 6px 0;opacity:.8}.live-row:hover{border-color:rgba(255,23,68,.45);transform:translateY(-1px);box-shadow:0 12px 36px rgba(0,0,0,.28)}.team{display:grid;grid-template-columns:auto 1fr;align-items:center;gap:12px;min-width:0}.team.away{grid-template-columns:1fr auto;text-align:right}.logo{width:58px;height:58px;border-radius:50%;background:#1c2d42;border:1px solid var(--line);display:flex;align-items:center;justify-content:center;overflow:hidden}.logo img{width:100%;height:100%;object-fit:contain;padding:6px}.name{font-family:var(--fd);font-size:22px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.side{font-size:10px;color:var(--t3);letter-spacing:1.2px;text-transform:uppercase;margin-top:2px}.scorebox{text-align:center;min-width:120px}.score{font-family:var(--fd);font-size:48px;font-weight:900;line-height:1;color:var(--t1)}.minute{display:inline-flex;align-items:center;gap:7px;margin-top:9px;border:1px solid rgba(255,23,68,.25);background:rgba(255,23,68,.1);color:var(--live);border-radius:20px;padding:5px 12px;font-family:var(--fd);font-size:12px;font-weight:900;letter-spacing:1px}.meta{display:flex;align-items:center;justify-content:center;gap:12px;margin-top:10px;font-size:11px;color:var(--t3);letter-spacing:1px;text-transform:uppercase}.live-dot{width:9px;height:9px;border-radius:50%;background:var(--live);box-shadow:0 0 0 rgba(255,23,68,.7);animation:pulseLive 1s infinite}@@keyframes pulseLive{0%{box-shadow:0 0 0 0 rgba(255,23,68,.7)}70%{box-shadow:0 0 0 10px rgba(255,23,68,0)}100%{box-shadow:0 0 0 0 rgba(255,23,68,0)}}.empty{background:var(--card);border:1px solid var(--line);border-radius:var(--r3);padding:48px;text-align:center;color:var(--t2)}@@media(max-width:800px){.hero-grid,.live-row{grid-template-columns:1fr}.onair{grid-template-columns:repeat(3,1fr)}.team,.team.away{grid-template-columns:1fr;text-align:center}.team.away .logo{order:0}.team .logo{margin:0 auto}.scorebox{margin:0 auto}.score{font-size:44px}.live-row{padding:18px}.live-row::before{top:16px;bottom:16px}.name{font-size:19px}}
</style>
}
<nav class="nb"><div class="nb-inner"><a asp-controller="Matches" asp-action="Index" class="brand"><img src="~/images/yilmazleaguelogo.png" asp-append-version="true" alt="YilmazLeague" class="brand-logo" /></a><div class="nav-links d-none d-lg-flex"><a asp-controller="Matches" asp-action="Index" class="nl">Ana Sayfa</a><a asp-controller="Live" asp-action="Index" class="nl active">Canlı Skorlar</a><a asp-controller="Fixtures" asp-action="Index" class="nl">Fikstür</a><a asp-controller="Standings" asp-action="Index" class="nl">Puan Durumu</a>@if (Context.Session.GetString("IsAdmin") == "true") { <a asp-controller="Admin" asp-action="Index" class="nl">Admin</a> }</div></div></nav>
<section class="hero"><div class="wrap"><div class="hero-grid"><div><div class="badge"><span class="live-dot"></span> Yayında</div><h1 class="title">Canlı <span style="color:var(--live)">Skorlar</span></h1><p class="sub">Devam eden maçlar, skorlar ve dakika bilgisi</p></div><div class="onair"><div class="onair-box"><div class="onair-num">@matches.Count</div><div class="onair-label">Canlı</div></div><div class="onair-box"><div class="onair-num">@(matches.Any() ? matches.Max(x => x.LiveMinute ?? 0) : 0)</div><div class="onair-label">En İleri Dk</div></div><div class="onair-box"><div class="onair-num">@matches.Select(x => x.WeekNumber).Distinct().Count()</div><div class="onair-label">Hafta</div></div></div></div></div></section>
<main class="wrap"><div class="content">
@if(!matches.Any())
{
    <div class="empty">Şu anda canlı maç bulunmuyor. Admin panelde maç durumu Canlı olduğunda burada görünür.</div>
}
else
{
    <div class="live-list">
    @foreach(var match in matches)
    {
        <a class="live-row" asp-controller="Matches" asp-action="Detail" asp-route-id="@match.LeagueMatchId">
            <div class="team home"><div class="logo"><img src="@match.HomeTeamLogo" alt="@match.HomeTeamName" onerror="this.style.display='none'" /></div><div><div class="name">@match.HomeTeamName</div><div class="side">Ev Sahibi</div></div></div>
            <div class="scorebox"><div class="score">@(match.HomeScore ?? 0)-@(match.AwayScore ?? 0)</div><div class="minute"><span class="live-dot"></span> CANLI · @(match.LiveMinute ?? 0)'</div><div class="meta"><span>@match.WeekNumber. Hafta</span><span>Detaya git</span></div></div>
            <div class="team away"><div><div class="name">@match.AwayTeamName</div><div class="side">Deplasman</div></div><div class="logo"><img src="@match.AwayTeamLogo" alt="@match.AwayTeamName" onerror="this.style.display='none'" /></div></div>
        </a>
    }
    </div>
}
</div></main>
